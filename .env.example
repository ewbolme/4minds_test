# Copy this file to .env and fill in your values

# 4minds credentials
FOURMIND_API_KEY=your_4minds_api_key_here
FOURMIND_DATASET_ID=your_pdf_dataset_id_here
FOURMIND_MUSIQUE_DATASET_ID=your_musique_dataset_id_here
FOURMIND_MODEL_ID=your_model_id_here

# OpenAI credentials
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_JUDGE_MODEL=gpt-5.1

# Optional: seconds to wait between 4minds inference requests (default 1.0)
# REQUEST_DELAY_SECONDS=1.0
